# Shared
APP_ENV=development
PUBLIC_WEB_URL=http://localhost:3000
API_BASE_URL=http://localhost:8080

# API
API_HOST=0.0.0.0
API_PORT=8080
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# PostgreSQL
DATABASE_URL=postgres://tipdrop:tipdrop@localhost:5432/tipdrop?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# RabbitMQ
RABBITMQ_URL=amqp://tipdrop:tipdrop@localhost:5672/

# S3-compatible storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=tipdrop-local
S3_ACCESS_KEY_ID=tipdrop
S3_SECRET_ACCESS_KEY=tipdrop-secret
S3_FORCE_PATH_STYLE=true

# OAuth
GOOGLE_OAUTH_CLIENT_ID=
FACEBOOK_OAUTH_APP_ID=
FACEBOOK_OAUTH_APP_SECRET=
FACEBOOK_LOGIN_ENABLED=false

# OTP/SMS
OTP_DEV_LOG=true
SMS_PROVIDER=dev
SMS_API_KEY=

# Firebase Cloud Messaging
FCM_PROJECT_ID=
FCM_CREDENTIALS_JSON=

# Flutter
FLUTTER_APP_SCHEME=tipdrop

# Next.js
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
